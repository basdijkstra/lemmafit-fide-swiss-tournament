  "specContent": "entries:\n  - id: spec-001\n    req_id: null\n    title: Participant count is between 2 and 19 when tournament is active or finished\n    group: Tournament Setup\n    layer: logic\n    type: invariant\n    property: \"m.phase != Setup ==> 2 <= |m.participants| <= 19\"\n    module: AppCore\n    depends_on: []\n    verifiable: true\n    guarantee_type: verified\n    state: ADDRESSED\n\n  - id: spec-002\n    req_id: null\n    title: Total rounds is at least 1 when tournament is active or finished\n    group: Tournament Setup\n    layer: logic\n    type: invariant\n    property: \"m.phase != Setup ==> m.totalRounds >= 1\"\n    module: AppCore\n    depends_on: []\n    verifiable: true\n    guarantee_type: verified\n    state: ADDRESSED\n\n  - id: spec-003\n    req_id: null\n    title: Current round count never exceeds total rounds\n    group: Tournament Setup\n    layer: logic\n    type: invariant\n    property: \"CurrentRound(m) <= m.totalRounds\"\n    module: AppCore\n    depends_on: [spec-001, spec-002]\n    verifiable: true\n    guarantee_type: verified\n    state: ADDRESSED\n\n  - id: spec-004\n    req_id: null\n    title: Participants have non-negative scores at all times\n    group: Scoring\n    layer: logic\n    type: invariant\n    property: \"forall i :: 0 <= i < |m.participants| ==> m.participants[i].score2x >= 0\"\n    module: AppCore\n    depends_on: []\n    verifiable: true\n    guarantee_type: verified\n    state: ADDRESSED\n\n  - id: spec-005\n    req_id: null\n    title: Opponent tracking is symmetric across all participants (FIDE Rule 2 foundation)\n    group: Pairing Rules\n    layer: logic\n    type: invariant\n    property: \"OpponentsSymmetric(m.participants)\"\n    module: AppCore\n    depends_on: []\n    verifiable: true\n    guarantee_type: verified\n    state: ADDRESSED\n\n  - id: spec-006\n    req_id: null\n    title: Accepted round pairings contain no rematches between participants (FIDE Rule 2)\n    group: Pairing Rules\n    layer: logic\n    type: postcondition\n    property: \"ValidPairingsForModel(m, pairings, bye) ==> NoRematchPairings(m.participants, pairings)\"\n    module: AppCore\n    depends_on: [spec-005]\n    verifiable: true\n    guarantee_type: verified\n    state: ADDRESSED\n\n  - id: spec-007\n    req_id: null\n    title: Each participant appears at most once in accepted round pairings (FIDE Rule 3)\n    group: Pairing Rules\n    layer: logic\n    type: postcondition\n    property: \"ValidPairingsForModel(m, pairings, bye) ==> PairingsDistinct(pairings)\"\n    module: AppCore\n    depends_on: []\n    verifiable: true\n    guarantee_type: verified\n    state: ADDRESSED\n\n  - id: spec-008\n    req_id: null\n    title: A bye is present when and only when the participant count is odd (FIDE Rule 3)\n    group: Pairing Rules\n    layer: logic\n    type: postcondition\n    property: \"ValidPairingsForModel(m, pairings, bye) ==> (bye.Some? <==> |m.participants| % 2 == 1)\"\n    module: AppCore\n    depends_on: [spec-001]\n    verifiable: true\n    guarantee_type: verified\n    state: ADDRESSED\n\n  - id: spec-009\n    req_id: null\n    title: Accepted bye recipient has not previously received a pairing-allocated bye (FIDE Rule 4)\n    group: Pairing Rules\n    layer: logic\n    type: postcondition\n    property: \"ValidPairingsForModel(m, pairings, bye) && bye.Some? ==> !m.participants[bye.value].byeReceived\"\n    module: AppCore\n    depends_on: []\n    verifiable: true\n    guarantee_type: verified\n    state: ADDRESSED\n\n  - id: spec-010\n    req_id: null\n    title: Active round always has structurally valid pairings and valid participant indices\n    group: Pairing Rules\n    layer: logic\n    type: invariant\n    property: \"ActiveRoundValid(m)\"\n    module: AppCore\n    depends_on: [spec-001]\n    verifiable: true\n    guarantee_type: verified\n    state: ADDRESSED\n\n  - id: spec-011\n    req_id: null\n    title: Color history length equals total games played as white plus black for every participant\n    group: Pairing Rules\n    layer: logic\n    type: invariant\n    property: \"forall i :: 0 <= i < |m.participants| ==> |m.participants[i].colorHistory| == m.participants[i].whiteCount + m.participants[i].blackCount\"\n    module: AppCore\n    depends_on: []\n    verifiable: true\n    guarantee_type: verified\n    state: ADDRESSED\n\n  - id: spec-012\n    req_id: null\n    title: Color difference for every participant stays within minus 2 to 2 (FIDE Rule 6)\n    group: Pairing Rules\n    layer: logic\n    type: postcondition\n    property: \"ChooseColorsPreservesColorDiff(p1, p2) ==> -2 <= ColorDiff(ApplyColor(p, c)) <= 2\"\n    module: AppCore\n    depends_on: [spec-011]\n    verifiable: true\n    guarantee_type: verified\n    state: ADDRESSED\n\n  - id: spec-013\n    req_id: null\n    title: No participant receives the same color three times consecutively (FIDE Rule 7)\n    group: Pairing Rules\n    layer: logic\n    type: postcondition\n    property: \"NoThreeConsecutive(p.colorHistory) && c != LastColor(p) ==> NoThreeConsecutive(p.colorHistory + [c])\"\n    module: AppCore\n    depends_on: [spec-011]\n    verifiable: true\n    guarantee_type: verified\n    state: ADDRESSED\n\n  - id: spec-014\n    req_id: null\n    title: All accepted pairings cover every participant exactly once (bye or paired)\n    group: Pairing Rules\n    layer: logic\n    type: postcondition\n    property: \"ValidPairingsForModel(m, pairings, bye) ==> 2 * |pairings| + (if bye.Some? then 1 else 0) == |m.participants|\"\n    module: AppCore\n    depends_on: [spec-001, spec-007, spec-008]\n    verifiable: true\n    guarantee_type: verified\n    state: ADDRESSED\n\n  - id: spec-015\n    req_id: null\n    title: Tournament setup screen allows entering participant names and number of rounds\n    group: Presentation\n    layer: presentation\n    type: invariant\n    property: \"Setup phase renders a form for participant names and a round count selector\"\n    module: null\n    depends_on: []\n    verifiable: false\n    guarantee_type: trusted\n    state: null\n\n  - id: spec-016\n    req_id: null\n    title: Pairings view shows White vs Black participant names for each game in the active round\n    group: Presentation\n    layer: presentation\n    type: invariant\n    property: \"Active round screen displays each pairing as white-player vs black-player\"\n    module: null\n    depends_on: []\n    verifiable: false\n    guarantee_type: trusted\n    state: null\n\n  - id: spec-017\n    req_id: null\n    title: User can record game results as White wins, Black wins, or Draw for each pairing\n    group: Presentation\n    layer: presentation\n    type: invariant\n    property: \"Result entry UI shows WhiteWins, BlackWins, Draw buttons per pairing\"\n    module: null\n    depends_on: []\n    verifiable: false\n    guarantee_type: trusted\n    state: null\n\n  - id: spec-018\n    req_id: null\n    title: Standings table displays all participants sorted by score descending after each round\n    group: Presentation\n    layer: presentation\n    type: invariant\n    property: \"Standings shows rank, name, and score for all participants in descending score order\"\n    module: null\n    depends_on: []\n    verifiable: false\n    guarantee_type: trusted\n    state: null\n",
  "ackedSpecContent": "entries: []\n",
